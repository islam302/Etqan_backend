# ---- Django core ----
# Set DJANGO_SETTINGS_MODULE=config.settings.prod in production
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database ----
# If unset, the project falls back to local SQLite (db.sqlite3).
# Example: postgres://etqan:etqan@localhost:5432/etqan
DATABASE_URL=

# ---- CORS ----
# Comma-separated list of frontend origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- JWT lifetimes (minutes / days) ----
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- Email (contact notifications) ----
# If EMAIL_HOST is empty, messages are only saved (no email sent).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@etqan.agency
# Where new contact-message notifications are sent:
CONTACT_NOTIFY_EMAIL=hello@etqan.agency

# ---- HTTPS / security (prod settings only) ----
# Keep True behind a real TLS proxy. Set to False to run the prod image over
# plain HTTP locally (otherwise requests are 301-redirected to https://).
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ---- Media / static ----
MEDIA_URL=/media/
STATIC_URL=/static/

# ---- Admin theme ----
USE_JAZZMIN=True
