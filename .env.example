# ---- Django core ----
# Set DJANGO_SETTINGS_MODULE=config.settings.prod in production
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database ----
# If unset, the project falls back to local SQLite (db.sqlite3).
# Example: postgres://etqan:etqan@localhost:5432/etqan
DATABASE_URL=

# ---- CORS ----
# Comma-separated list of frontend origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- JWT lifetimes (minutes / days) ----
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- Email (contact notifications) ----
# Contact-form submissions are emailed to CONTACT_NOTIFY_EMAIL. Without SMTP
# configured, mail is printed to the console (dev) instead of actually sent.
#
# Gmail example (recommended for etqan.agency.company@gmail.com):
#   1. Enable 2-Step Verification on the Google account.
#   2. Create an App Password: Google Account > Security > App passwords.
#   3. Put that 16-char app password (no spaces) in EMAIL_HOST_PASSWORD below.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=etqan.agency.company@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-gmail-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=etqan.agency.company@gmail.com
# Where new contact-form messages are sent (the agency inbox):
CONTACT_NOTIFY_EMAIL=etqan.agency.company@gmail.com

# ---- Social auth (server verifies provider tokens; leave blank to disable) ----
# Comma-separated to allow multiple platform client IDs (web, iOS, Android).
GOOGLE_CLIENT_ID=
# Apple "client id" = your Service ID (web) and/or app Bundle ID (iOS).
APPLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ---- HTTPS / security (prod settings only) ----
# Keep True behind a real TLS proxy. Set to False to run the prod image over
# plain HTTP locally (otherwise requests are 301-redirected to https://).
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ---- Media / static ----
MEDIA_URL=/media/
STATIC_URL=/static/

# ---- Admin theme ----
USE_JAZZMIN=True
