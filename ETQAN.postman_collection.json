{
  "info": {
    "name": "ETQAN Backend API",
    "_postman_id": "etqan-backend-collection",
    "description": "Complete collection for the ETQAN software-agency REST API (Django + DRF).\n\n## Getting started\n1. Import this collection.\n2. Set the collection variable `base_url` (default `http://localhost:8000`).\n3. Run **Auth > Login** — the access & refresh tokens are captured automatically into collection variables, so all admin (write) requests below are pre-authorized.\n\nPublic GET endpoints need no auth. Write endpoints (POST/PUT/PATCH/DELETE) send `Authorization: Bearer {{access_token}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "admin_email", "value": "admin@etqan.agency", "type": "string" },
    { "key": "admin_password", "value": "Admin12345!", "type": "string" },
    { "key": "project_slug", "value": "nimbus-analytics-platform", "type": "string" },
    { "key": "service_slug", "value": "web-development", "type": "string" },
    { "key": "blog_slug", "value": "building-the-future-of-software", "type": "string" },
    { "key": "message_id", "value": "", "type": "string", "description": "A ContactMessage UUID — copy one from the 'List messages' response." }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.code === 200);",
                  "const data = pm.response.json();",
                  "if (data.access) {",
                  "  pm.collectionVariables.set('access_token', data.access);",
                  "  console.log('access_token saved');",
                  "}",
                  "if (data.refresh) {",
                  "  pm.collectionVariables.set('refresh_token', data.refresh);",
                  "  console.log('refresh_token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login", ""] },
            "description": "Obtain a JWT access/refresh pair. On success the tokens are auto-saved to collection variables."
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access) pm.collectionVariables.set('access_token', data.access);",
                  "if (data.refresh) pm.collectionVariables.set('refresh_token', data.refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/refresh/", "host": ["{{base_url}}"], "path": ["api", "auth", "refresh", ""] }
          }
        },
        {
          "name": "Me (current admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/me/", "host": ["{{base_url}}"], "path": ["api", "auth", "me", ""] }
          }
        },
        {
          "name": "Logout (blacklist refresh)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/logout/", "host": ["{{base_url}}"], "path": ["api", "auth", "logout", ""] }
          }
        }
      ]
    },
